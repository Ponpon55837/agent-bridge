#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
usage() {
  cat <<'EOF'
Usage: agent-bridge <command> [options]

Commands:
  setup       Prepare the current project for Agent Bridge
  up          Start the default workflow for the current project
  down        Stop the default workflow
  doctor      Check local prerequisites
  start       Create or reuse a tmux workflow session
  install     Add runtime ignore rules to a project
  status      Show session and runtime state
  stop        Stop the supervisor and tmux session
  sessions    List sessions and mark the current one
  switch      Attach to or switch to a session
  rename      Rename a session safely
  kill        Kill one exact session (confirmation required)
  uninstall   Dry-run removal; use --force to remove runtime state
  validate    Run shell syntax and configuration checks
  (start also accepts --panes, --implementer-runtime, and --reviewer-runtime)
  help        Show this help
EOF
}
command="${1:-help}"; shift || true
case "$command" in
  setup)
    project="$(pwd)"; [[ "${1:-}" == "--project" ]] && project="$2"
    exec "$ROOT/scripts/agent-bridge-install.sh" --project "$project" --copy-config
    ;;
  up)
    project="$(pwd)"; session=""; implementer="opencode"; reviewer="opencode"
    while [[ $# -gt 0 ]]; do case "$1" in --project) project="$2"; shift 2;; --session) session="$2"; shift 2;; --implementer-runtime) implementer="$2"; shift 2;; --reviewer-runtime) reviewer="$2"; shift 2;; *) echo "unknown option: $1" >&2; exit 1;; esac; done
    [[ -n "$session" ]] || session="$(basename "$(cd "$project" && pwd)")-ai"
    "$ROOT/scripts/agent-bridge-install.sh" --project "$project"
    exec "$ROOT/scripts/agent-bridge.sh" --project "$project" --session "$session" --implementer-runtime "$implementer" --reviewer-runtime "$reviewer"
    ;;
  down)
    project="$(pwd)"; session="$(basename "$(pwd)")-ai"
    while [[ $# -gt 0 ]]; do case "$1" in --project) project="$2"; shift 2;; --session) session="$2"; shift 2;; *) echo "unknown option: $1" >&2; exit 1;; esac; done
    exec "$ROOT/scripts/agent-bridge-stop.sh" --project "$project" --session "$session"
    ;;
  doctor)
    failed=0
    echo "Agent Bridge 環境檢查"
    echo "系統: $(uname -s 2>/dev/null || echo unknown)"
    echo "Shell: ${BASH_VERSION:+bash} ${ZSH_VERSION:+zsh}"
    echo "目前指令: ${BASH_SOURCE[0]:-agent-bridge}"
    if command -v agent-bridge >/dev/null 2>&1; then echo "ok: agent-bridge ($(command -v agent-bridge))"; else echo "找不到 agent-bridge：請重新開啟終端機，或執行 ~/.local/bin/agent-bridge doctor"; failed=1; fi
    for tool in tmux python3; do command -v "$tool" >/dev/null 2>&1 && echo "ok: $tool" || { echo "缺少必要工具: $tool"; failed=1; }; done
    for tool in codex opencode claude; do command -v "$tool" >/dev/null 2>&1 && echo "available: $tool" || echo "optional: $tool not installed"; done
    if [[ ":${PATH}:" != *":$HOME/.local/bin:"* ]]; then
      echo "提示：目前終端機尚未載入 ~/.local/bin。請關閉後重新開啟，或執行："
      echo '  export PATH="$HOME/.local/bin:$PATH"'
    fi
    exit "$failed"
    ;;
  start) exec "$ROOT/scripts/agent-bridge.sh" "$@";;
  install) exec "$ROOT/scripts/agent-bridge-install.sh" "$@";;
  stop) exec "$ROOT/scripts/agent-bridge-stop.sh" "$@";;
  uninstall) exec "$ROOT/scripts/agent-bridge-uninstall.sh" "$@";;
  status)
    session="agent-bridge-dev"; project="$(pwd)"
    while [[ $# -gt 0 ]]; do case "$1" in --session) session="$2"; shift 2;; --project) project="$2"; shift 2;; *) echo "unknown option: $1" >&2; exit 1;; esac; done
    project="$(cd "$project" && pwd)"; runtime="$project/.ai-bridge"
    echo "project=$project"; echo "session=$session"
    if tmux has-session -t "$session" 2>/dev/null; then echo "tmux=running"; tmux list-panes -t "$session" -F 'pane=#{pane_index} title=#{pane_title} command=#{pane_current_command}'; else echo "tmux=stopped"; fi
    if [[ -f "$runtime/state/supervisor.pid" ]] && kill -0 "$(<"$runtime/state/supervisor.pid")" 2>/dev/null; then echo "supervisor=running pid=$(<"$runtime/state/supervisor.pid")"; else echo "supervisor=stopped"; fi
    echo "runtime=$runtime"; echo "mailbox_files=$(find "$runtime/mailbox" -type f 2>/dev/null | wc -l | tr -d ' ')"
    ;;
  sessions) exec "$ROOT/scripts/agent-bridge-sessions.sh" "$@";;
  switch) exec "$ROOT/scripts/agent-bridge-switch.sh" "$@";;
  rename) exec "$ROOT/scripts/agent-bridge-rename.sh" "$@";;
  kill) exec "$ROOT/scripts/agent-bridge-kill.sh" "$@";;
  validate)
    for file in "$ROOT"/scripts/*.sh "$ROOT"/scripts/agent-bridge; do bash -n "$file"; done
    [[ -f "$ROOT/.ai-bridge.example.yaml" ]] || { echo "missing example config" >&2; exit 1; }
    echo "validation passed"
    ;;
  help|-h|--help) usage;;
  *) echo "unknown command: $command" >&2; usage >&2; exit 1;;
esac
