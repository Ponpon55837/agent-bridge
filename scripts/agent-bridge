#!/usr/bin/env bash
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [[ -h "$SOURCE" ]]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  LINK="$(readlink "$SOURCE")"
  [[ "$LINK" == /* ]] && SOURCE="$LINK" || SOURCE="$SOURCE_DIR/$LINK"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
usage() {
  cat <<'EOF'
Usage: agent-bridge <command> [options]

Commands:
  setup       Prepare the current project for Agent Bridge
  up          Start the default workflow for the current project
  down        Stop the default workflow
  doctor      Check local prerequisites, runtimes, and MCP bridge tooling
  start       Create or reuse a detached tmux workflow session
  install     Add runtime ignore rules to a project
  status      Show session and runtime state
  logs        Show supervisor and handoff logs
  stop        Stop the supervisor and tmux session
  restart     Stop and start the workflow again
  recover     Check and optionally recover a stale supervisor
  sessions    List sessions and mark the current one
  switch      Attach to or switch to a session
  rename      Rename a session safely
  kill        Kill one exact session (confirmation required)
  uninstall   Dry-run removal; use --force to remove runtime state
  validate    Run shell syntax and configuration checks
  (start/up also accepts --config, --panes, --preset, --implementer-runtime, and --reviewer-runtime)
  help        Show this help
EOF
}
command="${1:-help}"; shift || true
case "$command" in
  setup)
    project="$(pwd)"; refresh=""
    while [[ $# -gt 0 ]]; do case "$1" in --project) project="$2"; shift 2;; --refresh-config) refresh="--refresh-config"; shift;; *) echo "unknown option: $1" >&2; exit 1;; esac; done
    exec "$ROOT/scripts/agent-bridge-install.sh" --project "$project" --copy-config $refresh
    ;;
  init)
    project="$(pwd)"
    while [[ $# -gt 0 ]]; do case "$1" in --project) project="$2"; shift 2;; --refresh-config) refresh="--refresh-config"; shift;; *) echo "unknown option: $1" >&2; exit 1;; esac; done
    exec "$ROOT/scripts/agent-bridge-install.sh" --project "$project" --copy-config ${refresh:-}
    ;;
  up)
    project="$(pwd)"; session=""; config=""; requested_panes=""; extra=()
    [[ -t 0 && -t 1 ]] && extra+=(--attach)
    while [[ $# -gt 0 ]]; do case "$1" in --project) project="$2"; shift 2;; --config) config="$2"; extra+=(--config "$2"); shift 2;; --session) session="$2"; extra+=(--session "$session"); shift 2;; --panes) requested_panes="$2"; extra+=(--panes "$2"); shift 2;; --implementer-runtime|--reviewer-runtime|--orchestrator-runtime|--preset) extra+=("$1" "$2"); shift 2;; *) echo "unknown option: $1" >&2; exit 1;; esac; done
    "$ROOT/scripts/agent-bridge-install.sh" --project "$project"
    if [[ -z "$session" && -n "$config" ]]; then
      [[ -f "$config" ]] || { [[ -f "$project/$config" ]] && config="$project/$config"; }
      [[ -f "$config" ]] || { echo "config file does not exist: $config" >&2; exit 1; }
      session="$(python3 "$ROOT/scripts/config-loader.py" "$config" | sed -n 's/^CONFIG_SESSION=//p' | sed "s/^'//; s/'$//")"
    elif [[ -z "$session" && -f "$project/.ai-bridge.yaml" ]]; then
      session="$(python3 "$ROOT/scripts/config-loader.py" "$project/.ai-bridge.yaml" | sed -n 's/^CONFIG_SESSION=//p' | sed "s/^'//; s/'$//")"
    fi
    [[ -n "$session" ]] || session="$(basename "$(cd "$project" && pwd)")-ai"
    if tmux has-session -t "$session" 2>/dev/null; then
      expected_panes="$requested_panes"
      if [[ -z "$expected_panes" ]]; then
        if [[ -n "$config" ]]; then
          expected_panes="$(python3 "$ROOT/scripts/config-loader.py" "$config" | sed -n 's/^CONFIG_PANES=//p' | sed "s/^'//; s/'$//")"
        elif [[ -f "$project/.ai-bridge.yaml" ]]; then
          expected_panes="$(python3 "$ROOT/scripts/config-loader.py" "$project/.ai-bridge.yaml" | sed -n 's/^CONFIG_PANES=//p' | sed "s/^'//; s/'$//")"
        fi
      fi
      actual_panes="$(tmux list-panes -t "$session:0" 2>/dev/null | wc -l | tr -d ' ')"
      if [[ -n "$expected_panes" && "$actual_panes" != "$expected_panes" ]]; then
        echo "session '$session' has $actual_panes panes, requested $expected_panes panes." >&2
        echo "Stop the existing session before switching pane topology: agent-bridge down --session $session" >&2
        exit 1
      fi
      exec "$ROOT/scripts/agent-bridge-switch.sh" "$session"
    fi
    if ((${#extra[@]} > 0)); then
      exec "$ROOT/scripts/agent-bridge.sh" --project "$project" "${extra[@]}"
    else
      exec "$ROOT/scripts/agent-bridge.sh" --project "$project" --session "$session"
    fi
    ;;
  down)
    project="$(pwd)"; session="$(basename "$(pwd)")-ai"; explicit_session=0
    while [[ $# -gt 0 ]]; do case "$1" in --project) project="$2"; shift 2;; --session) session="$2"; explicit_session=1; shift 2;; *) echo "unknown option: $1" >&2; exit 1;; esac; done
    if (( ! explicit_session )) && [[ -f "$project/.ai-bridge.yaml" ]]; then
      session="$(python3 "$ROOT/scripts/config-loader.py" "$project/.ai-bridge.yaml" | sed -n 's/^CONFIG_SESSION=//p' | sed "s/^'//; s/'$//")"
    fi
    exec "$ROOT/scripts/agent-bridge-stop.sh" --project "$project" --session "$session"
    ;;
  doctor)
    failed=0
    echo "Agent Bridge 環境檢查"
    echo "系統: $(uname -s 2>/dev/null || echo unknown)"
    case "$(uname -s 2>/dev/null || true)" in
      MINGW*|MSYS*|CYGWIN*)
        echo "Windows shell detected: Bash and tmux must both be available in this environment."
        echo "推薦使用 WSL2 Ubuntu；PowerShell/CMD 不能直接執行 Agent Bridge Bash scripts."
        ;;
    esac
    echo "Shell: ${BASH_VERSION:+bash} ${ZSH_VERSION:+zsh}"
    echo "目前指令: ${BASH_SOURCE[0]:-agent-bridge}"
    if command -v agent-bridge >/dev/null 2>&1; then echo "ok: agent-bridge ($(command -v agent-bridge))"; else echo "找不到 agent-bridge：請重新開啟終端機，或執行 ~/.local/bin/agent-bridge doctor"; failed=1; fi
    for tool in tmux python3 node npx; do command -v "$tool" >/dev/null 2>&1 && echo "ok: $tool" || { echo "缺少必要工具: $tool"; failed=1; }; done
    if command -v npx >/dev/null 2>&1; then
      echo "MCP bridge: tmux-bridge-mcp (configure with: npx -y tmux-bridge-mcp setup)"
    else
      echo "缺少 MCP bridge：先安裝 Node.js 18+，再執行 npx -y tmux-bridge-mcp setup" >&2
    fi
    for tool in codex opencode claude; do command -v "$tool" >/dev/null 2>&1 && echo "available: $tool" || echo "optional: $tool not installed"; done
    if [[ ":${PATH}:" != *":$HOME/.local/bin:"* ]]; then
      echo "提示：目前終端機尚未載入 ~/.local/bin。請關閉後重新開啟，或執行："
      echo '  export PATH="$HOME/.local/bin:$PATH"'
    fi
    exit "$failed"
    ;;
  start) exec "$ROOT/scripts/agent-bridge.sh" "$@";;
  install) exec "$ROOT/scripts/agent-bridge-install.sh" "$@";;
  stop) exec "$ROOT/scripts/agent-bridge-stop.sh" "$@";;
  restart)
    project="$(pwd)"; session=""; restart_args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --project) project="$2"; restart_args+=(--project "$2"); shift 2;;
        --session) session="$2"; restart_args+=(--session "$2"); shift 2;;
        --implementer-runtime|--reviewer-runtime|--orchestrator-runtime|--panes|--preset)
          restart_args+=("$1" "$2"); shift 2;;
        --detach|--attach) restart_args+=("$1"); shift;;
        *) echo "unknown option: $1" >&2; exit 1;;
      esac
    done
    if [[ -z "$session" && -f "$project/.ai-bridge.yaml" ]]; then
      session="$(python3 "$ROOT/scripts/config-loader.py" "$project/.ai-bridge.yaml" | sed -n "s/^CONFIG_SESSION='\?\([^']*\)'\?$/\1/p")"
      [[ -n "$session" ]] && restart_args+=(--session "$session")
    fi
    if [[ -z "$session" ]]; then
      session="$(basename "$(cd "$project" && pwd)")-ai"
      restart_args+=(--session "$session")
    fi
    if [[ -n "$session" ]]; then
      "$ROOT/scripts/agent-bridge-stop.sh" --project "$project" --session "$session"
    else
      "$ROOT/scripts/agent-bridge-stop.sh" --project "$project"
    fi
    exec "$ROOT/scripts/agent-bridge" up "${restart_args[@]}"
    ;;
  recover) exec "$ROOT/scripts/agent-bridge-recover.sh" "$@";;
  uninstall) exec "$ROOT/scripts/agent-bridge-uninstall.sh" "$@";;
  status)
    session="agent-bridge-dev"; project="$(pwd)"; output_json=0
    while [[ $# -gt 0 ]]; do case "$1" in --session) session="$2"; shift 2;; --project) project="$2"; shift 2;; --json) output_json=1; shift;; *) echo "unknown option: $1" >&2; exit 1;; esac; done
    project="$(cd "$project" && pwd)"; runtime="$project/.ai-bridge"
    tmux_state=stopped
    if tmux has-session -t "$session" 2>/dev/null; then tmux_state=running; fi
    supervisor_state=stopped; supervisor_health=stopped; supervisor_pid=""
    if [[ -f "$runtime/state/supervisor.pid" ]] && kill -0 "$(<"$runtime/state/supervisor.pid")" 2>/dev/null; then
      supervisor_pid="$(<"$runtime/state/supervisor.pid")"
      if [[ -f "$runtime/state/.supervisor-heartbeat" ]] && find "$runtime/state/.supervisor-heartbeat" -mmin -1 -print -quit 2>/dev/null | grep -q .; then
        supervisor_state=running; supervisor_health=healthy
      else
        supervisor_state=running; supervisor_health=stale
      fi
    fi
    mailbox_files=0
    if [[ -d "$runtime/mailbox" ]]; then
      mailbox_files="$(find "$runtime/mailbox" -type f 2>/dev/null | wc -l | tr -d ' ')"
    fi
    workflow_file="$runtime/state/workflow.json"
    if (( output_json )); then
      python3 -c 'import json,sys,os; state=None; path=sys.argv[9]; state=json.load(open(path,encoding="utf-8")) if os.path.isfile(path) else None; print(json.dumps({"project":sys.argv[1],"session":sys.argv[2],"tmux":sys.argv[3],"supervisor":sys.argv[4],"health":sys.argv[5],"supervisor_pid":int(sys.argv[6]) if sys.argv[6] else None,"runtime":sys.argv[7],"mailbox_files":int(sys.argv[8]),"workflow":state}, ensure_ascii=False))' \
        "$project" "$session" "$tmux_state" "$supervisor_state" "$supervisor_health" "$supervisor_pid" "$runtime" "$mailbox_files" "$workflow_file"
      exit 0
    fi
    echo "project=$project"; echo "session=$session"
    if [[ "$tmux_state" == running ]]; then echo "tmux=running"; tmux list-panes -t "$session" -F 'pane=#{pane_index} title=#{pane_title} command=#{pane_current_command}'; else echo "tmux=stopped"; fi
    if [[ "$supervisor_state" == running ]]; then echo "supervisor=running pid=$supervisor_pid health=$supervisor_health"; else echo "supervisor=stopped"; fi
    echo "runtime=$runtime"; echo "mailbox_files=$mailbox_files"
    [[ -f "$workflow_file" ]] && echo "workflow=$(<"$workflow_file")"
    ;;
  logs) exec "$ROOT/scripts/agent-bridge-logs.sh" "$@";;
  sessions) exec "$ROOT/scripts/agent-bridge-sessions.sh" "$@";;
  switch) exec "$ROOT/scripts/agent-bridge-switch.sh" "$@";;
  rename) exec "$ROOT/scripts/agent-bridge-rename.sh" "$@";;
  kill) exec "$ROOT/scripts/agent-bridge-kill.sh" "$@";;
  validate)
    project="$(pwd)"
    while [[ $# -gt 0 ]]; do case "$1" in --project) project="$2"; shift 2;; *) echo "unknown option: $1" >&2; exit 1;; esac; done
    for file in "$ROOT"/scripts/*.sh "$ROOT"/scripts/agent-bridge; do bash -n "$file"; done
    [[ -f "$ROOT/.ai-bridge.example.yaml" ]] || { echo "missing example config" >&2; exit 1; }
    project="$(cd "$project" 2>/dev/null && pwd)" || { echo "agent-bridge is not initialized for this project." >&2; echo "Missing: project directory" >&2; echo "Run: agent-bridge init" >&2; exit 1; }
    missing=()
    [[ -f "$project/.ai-bridge.yaml" ]] || missing+=(".ai-bridge.yaml")
    for tool in tmux python3 node npx; do command -v "$tool" >/dev/null 2>&1 || missing+=("command $tool"); done
    if ((${#missing[@]})); then
      echo "agent-bridge is not initialized for this project." >&2
      printf 'Missing: %s\n' "$(IFS=', '; echo "${missing[*]}")" >&2
      echo "Run: agent-bridge init" >&2
      exit 1
    fi
    python3 "$ROOT/scripts/config-loader.py" "$project/.ai-bridge.yaml" >/dev/null || { echo "invalid .ai-bridge.yaml" >&2; exit 1; }
    echo "validation passed"
    ;;
  help|-h|--help) usage;;
  *) echo "unknown command: $command" >&2; usage >&2; exit 1;;
esac
